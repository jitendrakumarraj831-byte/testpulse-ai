# Supabase — database + auth. Required for the app to do anything beyond
# render static/mock content.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Older Supabase projects call this the "anon key" instead — either works.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — required for admin-only server actions
# (deleting accounts, recording online fee payments) that RLS can never
# allow no matter the policy. Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Groq — powers AI chat, question generation/parsing, and performance
# analysis. Every AI route degrades to a deterministic fallback without it.
GROQ_API_KEY=
# AI_API_KEY=
# AI_MODEL=llama-3.3-70b-versatile

# Razorpay — online fee payment collection (Module 4.3). Without these,
# the student Fees page still shows dues but "Pay Now" is disabled with an
# explanatory message instead of erroring.
# Key ID is not secret and is also sent to the browser for Checkout, so it
# is read from NEXT_PUBLIC_RAZORPAY_KEY_ID; RAZORPAY_KEY_ID (server-only)
# is accepted as an alias if you'd rather not duplicate the value.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Configured separately from the key pair, on the webhook itself in the
# Razorpay dashboard (Settings > Webhooks > your webhook > Secret).
RAZORPAY_WEBHOOK_SECRET=
